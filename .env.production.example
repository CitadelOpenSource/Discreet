# ═══════════════════════════════════════════════════════════════════════════
# Discreet — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy to .env on your production server, fill in every value, then start.
# Or run scripts/generate-secrets.sh to auto-generate this file.
# Treat .env as SECRET — never commit a filled-in copy.
#
# ─── Secret generation (run each ONCE, save the output) ───────────────────
#   openssl rand -hex 32   → DB password, Redis password, TOTP key, agent key, TURN secret
#   openssl rand -hex 64   → JWT secret
# ═══════════════════════════════════════════════════════════════════════════


# ─── Required — server will not start without these ──────────────────────

DATABASE_URL=postgres://discreet:<DB_PASSWORD>@db:5432/discreet
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379
JWT_SECRET=<CHANGE_ME>
TOTP_ENCRYPTION_KEY=<CHANGE_ME>
AGENT_KEY_SECRET=<CHANGE_ME>


# ─── Deployment Mode ──────────────────────────────────────────────────────

RUST_ENV=production
# SELF_HOSTED=false


# ─── URLs ────────────────────────────────────────────────────────────────

PUBLIC_URL=https://<YOUR_DOMAIN>
APP_URL=https://<YOUR_DOMAIN>
API_URL=https://api.<YOUR_DOMAIN>
ALLOWED_ORIGINS=https://<YOUR_DOMAIN>


# ─── Network ─────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=3000


# ─── Database Tuning ─────────────────────────────────────────────────────

DATABASE_MAX_CONNECTIONS=20


# ─── Auth Tuning ─────────────────────────────────────────────────────────

JWT_EXPIRY_SECS=900
REFRESH_EXPIRY_SECS=604800


# ─── Email (Resend HTTP API) ─────────────────────────────────────────────

RESEND_API_KEY=<your-resend-api-key>
SMTP_FROM=noreply@<YOUR_DOMAIN>


# ─── CAPTCHA (Cloudflare Turnstile) ──────────────────────────────────────

# TURNSTILE_SITE_KEY=<from-cloudflare-dashboard>
# TURNSTILE_SECRET_KEY=<from-cloudflare-dashboard>


# ─── TURN Server (WebRTC voice/video relay) ──────────────────────────────

# TURN_SECRET=<openssl rand -hex 32>
# TURN_HOST=turn.<YOUR_DOMAIN>
# TURN_REALM=turn.<YOUR_DOMAIN>
# TURN_TTL=86400


# ─── AI Agents ───────────────────────────────────────────────────────────

# AGENTS_ENABLED=false
# AGENT_LLM_ENDPOINT=http://localhost:11434/api/generate
# MAX_AGENTS_PER_SERVER=50


# ─── Feature Flags ───────────────────────────────────────────────────────

# PQ_ENABLED=false
# FEDERATION_ENABLED=false
# FEDERATION_DOMAIN=<YOUR_DOMAIN>
# FEDERATION_PORT=8448


# ─── Rate Limiting ───────────────────────────────────────────────────────

RATE_LIMIT_PER_MINUTE=120


# ─── Uploads ─────────────────────────────────────────────────────────────

MAX_UPLOAD_BYTES=26214400


# ─── Logging ─────────────────────────────────────────────────────────────

LOG_FORMAT=json
RUST_LOG=discreet_server=info,tower_http=info
