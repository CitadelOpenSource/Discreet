# ═══════════════════════════════════════════════════════════════════════════
# Discreet — Production Environment Template
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy to .env on your production server, fill in every value, then start.
# Treat this file as SECRET — never commit a filled-in copy.
#
# ─── Secret generation (run each ONCE, save the output) ───────────────────
#
#   Database password:    openssl rand -hex 32
#   Redis password:       openssl rand -hex 32
#   JWT_SECRET:           openssl rand -hex 64
#   TOTP_ENCRYPTION_KEY:  openssl rand -hex 32
#   AGENT_KEY_SECRET:     openssl rand -hex 32
#   TURN_SECRET:          openssl rand -hex 32
#
# ═══════════════════════════════════════════════════════════════════════════


# ─── Deployment Mode ──────────────────────────────────────────────────────

# Set to "production" to enforce credential strength checks at startup.
RUST_ENV=production

# Self-hosted mode: enterprise tier for all users, relaxed credential
# checks, same-origin /api/v1 prefix assumed.  Set to false (or omit)
# for the hosted SaaS deployment.
SELF_HOSTED=false


# ─── Required — server will not start without these ──────────────────────

# PostgreSQL connection string.
# Generate password: openssl rand -hex 32
DATABASE_URL=postgres://discreet:GENERATED_DB_PASSWORD@db:5432/discreet

# Redis connection string.
# Generate password: openssl rand -hex 32
REDIS_URL=redis://:GENERATED_REDIS_PASSWORD@redis:6379

# JWT signing key — signs all access and refresh tokens.
# Generate: openssl rand -hex 64
JWT_SECRET=

# AES-256-GCM key for encrypting TOTP secrets at rest.
# Required in production. Without it, startup panics.
# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=


# ─── URLs (subdomain routing) ────────────────────────────────────────────

# Public-facing URL — email footers, Open Graph metadata, external links.
PUBLIC_URL=https://discreetai.net

# Frontend app URL — verification links, password reset links, CORS default.
APP_URL=https://app.discreetai.net

# API base URL — self-hosted instances leave blank for same-origin /api/v1.
API_URL=https://api.discreetai.net/api/v1


# ─── CORS ─────────────────────────────────────────────────────────────────

# Allowed origins for cross-origin requests (comma-separated).
# If omitted, defaults to APP_URL.  Set to "*" only in development.
CORS_ORIGINS=https://app.discreetai.net


# ─── Network ─────────────────────────────────────────────────────────────

# Bind address and port.  Behind a reverse proxy, 0.0.0.0:3000 is typical.
HOST=0.0.0.0
PORT=3000


# ─── Database Tuning ─────────────────────────────────────────────────────

# Max PostgreSQL connection pool size.
DATABASE_MAX_CONNECTIONS=20


# ─── Auth Tuning ──────────────────────────────────────────────────────────

# Access token lifetime in seconds (default: 900 = 15 min).
JWT_EXPIRY_SECS=900

# Refresh token lifetime in seconds (default: 604800 = 7 days).
REFRESH_EXPIRY_SECS=604800


# ─── Email (verification, password reset) ─────────────────────────────────

# Resend HTTP API key (https://resend.com).
# This is the only email transport currently implemented.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address on all outgoing email.
SMTP_FROM=noreply@discreetai.net

# ── Future SMTP support (not yet implemented — reserved) ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587


# ─── CAPTCHA (Cloudflare Turnstile) ──────────────────────────────────────

# If both keys are set, registration requires a Turnstile challenge.
# Omit for self-hosted / offline / proximity mesh deployments.
TURNSTILE_SITE_KEY=0x_YOUR_SITE_KEY
TURNSTILE_SECRET_KEY=0x_YOUR_SECRET_KEY


# ─── TURN Server (WebRTC voice/video relay) ──────────────────────────────

# Shared secret for ephemeral TURN credentials (HMAC-SHA1).
# Must match your CoTURN server's static-auth-secret.
# If not set, clients fall back to STUN-only (no relay behind symmetric NAT).
# Generate: openssl rand -hex 32
TURN_SECRET=

# Comma-separated TURN/TURNS server URLs.
TURN_URLS=turn:turn.discreetai.net:3478,turns:turn.discreetai.net:5349

# Credential lifetime in seconds (default: 86400 = 24 hours).
TURN_TTL=86400


# ─── Billing — Stripe ────────────────────────────────────────────────────

# Omit entire section if billing is not enabled.
# STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# STRIPE_PRICE_PRO=price_REPLACE_ME
# STRIPE_PRICE_TEAMS=price_REPLACE_ME
# STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME


# ─── Billing — BTCPay Server (cryptocurrency) ────────────────────────────

# BTCPAY_URL=https://btcpay.discreetai.net
# BTCPAY_STORE_ID=NOT-SET-UP-YET
# BTCPAY_API_KEY=NOT-SET-UP-YET
# BTCPAY_WEBHOOK_SECRET=NOT-SET-UP-YET


# ─── AI Agents ────────────────────────────────────────────────────────────

# Master toggle for the agent framework.
AGENTS_ENABLED=false

# Master secret for AES-256-GCM encryption of agent API keys at rest.
# Each agent derives a unique key: SHA-256(secret || ":" || agent_id).
# Generate: openssl rand -hex 32
AGENT_KEY_SECRET=

# Default LLM inference endpoint for managed agents (e.g., local Ollama).
# AGENT_LLM_ENDPOINT=http://localhost:11434/api/generate

# Max concurrent agents per server (default: 50).
# MAX_AGENTS_PER_SERVER=50

# ── OpenJarvis (self-hosted local AI provider) ──
# Fully private, no API key, localhost only.
OPENJARVIS_URL=http://localhost:8000

# ── Cloud provider API keys (server-side, encrypted at rest) ──
# Only needed if agents use cloud LLM providers.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CUSTOM_LLM_API_KEY=


# ─── Feature Flags ────────────────────────────────────────────────────────

# Post-quantum cryptography endpoints (experimental).
# PQ_ENABLED=false
# PQ_SECURITY_LEVEL=3

# Federation protocol (inter-instance messaging).
# FEDERATION_ENABLED=false
# FEDERATION_DOMAIN=discreetai.net
# FEDERATION_PORT=8448


# ─── Rate Limiting ────────────────────────────────────────────────────────

# Max requests per minute per IP address (default: 120).
RATE_LIMIT_PER_MINUTE=120


# ─── Uploads ──────────────────────────────────────────────────────────────

# Max upload body size in bytes (default: 26214400 = 25 MB).
MAX_UPLOAD_BYTES=26214400


# ─── Logging ──────────────────────────────────────────────────────────────

# "json" for SIEM / log aggregators, "pretty" for human-readable.
LOG_FORMAT=json
