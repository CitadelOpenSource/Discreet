# ═══════════════ Database ═══════════════
DATABASE_URL=postgres://discreet:CHANGE_ME@localhost:5432/discreet
# Required. Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Generate password: openssl rand -hex 16
# DATABASE_MAX_CONNECTIONS=20

# ═══════════════ Redis ═══════════════
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379
# Required. Include password if Redis is password-protected.

# ═══════════════ Authentication ═══════════════
JWT_SECRET=CHANGE_ME
# Required. Run: openssl rand -hex 64
# JWT_EXPIRY_SECS=900          # Access token lifetime (default: 15 minutes)
# REFRESH_EXPIRY_SECS=604800   # Refresh token lifetime (default: 7 days)

TOTP_ENCRYPTION_KEY=CHANGE_ME
# Required in production. Run: openssl rand -hex 32
# AES-256-GCM key for encrypting TOTP 2FA secrets at rest.

# ═══════════════ Email (Resend HTTP API) ═══════════════
RESEND_API_KEY=<your-resend-api-key>
# Required for email verification and password resets.
# Get a key at https://resend.com/api-keys (starts with re_)
SMTP_FROM=noreply@<YOUR_DOMAIN>

# ═══════════════ Application ═══════════════
# APP_URL=https://<YOUR_DOMAIN>        # Frontend URL, used as default CORS origin
# API_URL=https://api.<YOUR_DOMAIN>    # API URL for email links
# ALLOWED_ORIGINS=https://<YOUR_DOMAIN> # Comma-separated CORS origins
RUST_LOG=discreet_server=info,tower_http=info
# HOST=0.0.0.0
# PORT=3000
# SELF_HOSTED=false
# LOG_FORMAT=pretty     # pretty (default) or json (for SIEM / log aggregators)

# ═══════════════ AI Agents ═══════════════
AGENT_KEY_SECRET=CHANGE_ME
# Required. Run: openssl rand -hex 32
# Encrypts stored AI provider API keys at rest (AES-256-GCM).
# AGENTS_ENABLED=false
# AGENT_LLM_ENDPOINT=http://localhost:11434/api/generate
# MAX_AGENTS_PER_SERVER=50

# ═══════════════ Cloudflare Turnstile ═══════════════
# TURNSTILE_SITE_KEY=            # Public key (frontend widget)
# TURNSTILE_SECRET_KEY=          # Secret key (server verification)
# Used for anonymous account registration CAPTCHA.
# Not needed for self-hosted/offline deployments.

# ═══════════════ TURN Server ═══════════════
# TURN_SECRET=<openssl rand -hex 32>
# TURN_HOST=turn.<YOUR_DOMAIN>
# TURN_REALM=turn.<YOUR_DOMAIN>
# Shared secret must match coturn's static-auth-secret.
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# TURN_TTL=86400

# ═══════════════ OAuth Providers (all optional) ═══════════════
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# Leave blank to disable the provider's OAuth button.

# ═══════════════ Feature Flags ═══════════════
# PQ_ENABLED=false              # Post-quantum cryptography (ML-KEM, ML-DSA)
# FEDERATION_ENABLED=false      # Server federation protocol
# FEDERATION_DOMAIN=<YOUR_DOMAIN>
# FEDERATION_PORT=8448

# ═══════════════ Rate Limiting ═══════════════
# RATE_LIMIT_PER_MINUTE=120
# Per-IP global rate limit. Auth endpoints have stricter per-path limits.

# ═══════════════ Upload Limits ═══════════════
# MAX_UPLOAD_BYTES=26214400     # 25 MB default
