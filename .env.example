# ─── Required ────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# The setup script generates secure credentials automatically.
DATABASE_URL=postgres://discreet:CHANGE_ME@localhost:5432/discreet

# Redis connection string.
# Include password if Redis is password-protected (recommended).
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379

# JWT signing key — used for all authentication tokens.
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME

# ─── Required for Production ───────────────────────────
# CORS_ORIGINS — Controls allowed origins for cross-origin requests.
#   Not set → uses APP_URL if set, otherwise http://localhost:{PORT}
#   *       → allow all origins (development only)
#   URL(s)  → allow specific origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ─── URLs (subdomain routing) ─────────────────────────
# PUBLIC_URL — Public-facing URL. Used for email footers, Open Graph metadata.
# PUBLIC_URL=https://discreetai.net
#
# APP_URL — Frontend app URL. Used as default CORS origin when CORS_ORIGINS
#   is not set. Email verification and password reset links point here.
# APP_URL=https://app.discreetai.net
#
# API_URL — API base URL. Self-hosted instances default to same-origin /api/v1.
# API_URL=https://api.discreetai.net/api/v1
#
# SELF_HOSTED — If true, all users get enterprise tier, credential checks
#   are relaxed, and API defaults to same-origin /api/v1 prefix.
# SELF_HOSTED=false

# TOTP_ENCRYPTION_KEY — AES-256-GCM key for encrypting TOTP secrets at rest.
#   Required in production. Without it, a key is derived from JWT_SECRET (insecure).
#   Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=CHANGE_ME

# RATE_LIMIT_PER_MINUTE=60

# ─── Optional ────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=3000
# DATABASE_MAX_CONNECTIONS=20
# JWT_EXPIRY_SECS=900
# REFRESH_EXPIRY_SECS=604800
# LOG_FORMAT=pretty                    # pretty (default) or json (for SIEM / log aggregators)

# ─── Email (verification & password reset) ───────────────
# Resend HTTP API (recommended — https://resend.com)
# RESEND_API_KEY=re_xxx
# SMTP_FROM=noreply@yourdomain.com          # defaults to noreply@discreetai.net

# ─── CAPTCHA (Cloudflare Turnstile) ────────────────────
# Only needed for public-facing instances. Self-hosted, offline,
# and proximity mesh deployments work without CAPTCHA.
# TURNSTILE_SITE_KEY=0x...                  # public key, used by frontend widget
# TURNSTILE_SECRET_KEY=0x...                # secret key, used by server verification

# ─── TURN Server (WebRTC voice/video) ─────────────────
# Shared secret for generating ephemeral TURN credentials (HMAC-SHA1).
# Must match your CoTURN server's static-auth-secret.
# If not set, clients fall back to STUN-only (no relay).
# Generate with: openssl rand -hex 32
# TURN_SECRET=
#
# Comma-separated TURN server URLs.
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
#
# Credential lifetime in seconds (default: 86400 = 24 hours).
# TURN_TTL=86400

# ─── Feature Flags ──────────────────────────────────────
# PQ_ENABLED=false
# FEDERATION_ENABLED=false
# AGENTS_ENABLED=false
# AGENT_LLM_ENDPOINT=http://localhost:11434/api/generate

# ─── AI Agent Key Encryption ────────────────────────────
# Master secret used to derive per-agent AES-256-GCM keys for encrypting
# API keys stored in the database. Each agent gets a unique derived key:
#   per_agent_key = SHA-256(AGENT_KEY_SECRET || ":" || agent_id)
# Generate with: openssl rand -hex 32
# Required if any agent uses "bring your own key" (BYOK) API key config.
AGENT_KEY_SECRET=CHANGE_ME
