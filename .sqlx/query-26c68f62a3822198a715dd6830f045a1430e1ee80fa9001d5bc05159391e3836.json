  "query": "SELECT r.id, r.server_id, r.name, r.color, r.permissions, r.position, r.created_at\n         FROM member_roles mr\n         INNER JOIN roles r ON r.id = mr.role_id\n         WHERE mr.server_id = $1 AND mr.user_id = $2\n         ORDER BY r.position",
