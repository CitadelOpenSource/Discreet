{
  "db_name": "PostgreSQL",
  "query": "SELECT u.id AS user_id, u.username, u.display_name, u.is_bot, m.nickname, m.joined_at, m.notification_level, m.visibility_override\n         FROM server_members m\n         INNER JOIN users u ON u.id = m.user_id\n         WHERE m.server_id = $1\n         ORDER BY u.is_bot ASC, m.joined_at\n         LIMIT $2 OFFSET $3",
