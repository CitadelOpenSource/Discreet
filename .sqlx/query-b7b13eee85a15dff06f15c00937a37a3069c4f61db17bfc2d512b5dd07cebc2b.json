  "query": "UPDATE scheduled_tasks\n               SET last_run = NOW()\n               WHERE id IN (\n                   SELECT id FROM scheduled_tasks\n                   WHERE enabled = TRUE\n                     AND (next_run IS NULL OR next_run <= NOW())\n                   LIMIT 50\n               )\n               RETURNING id, server_id, channel_id, created_by, task_type,\n                         config, cron_expr",
