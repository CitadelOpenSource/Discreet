  "query": "SELECT id, dm_channel_id, sender_id, content_ciphertext, created_at\n             FROM dm_messages\n             WHERE dm_channel_id = $1\n               AND created_at < (SELECT created_at FROM dm_messages WHERE id = $2)\n             ORDER BY created_at DESC\n             LIMIT $3",
