{
  "db_name": "PostgreSQL",
  "query": "SELECT m.id, m.content_ciphertext, m.author_id, m.created_at, p.pinned_by, p.pinned_at\n         FROM pinned_messages p\n         JOIN messages m ON m.id = p.message_id\n         WHERE p.channel_id = $1\n         ORDER BY p.pinned_at DESC\n         LIMIT 50",
