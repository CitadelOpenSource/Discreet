{
  "db_name": "PostgreSQL",
  "query": "SELECT m.id, m.content_ciphertext, m.created_at, m.mls_epoch,\n                  u.username as \"author_username?\"\n           FROM messages m\n           LEFT JOIN users u ON u.id = m.author_id\n           WHERE m.channel_id = $1 AND m.deleted = FALSE\n           ORDER BY m.created_at DESC\n           LIMIT 200",
