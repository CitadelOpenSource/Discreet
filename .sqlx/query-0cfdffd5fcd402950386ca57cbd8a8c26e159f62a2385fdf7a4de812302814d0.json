  "query": "SELECT id, type, title, body, action_url, read, created_at\n               FROM notifications\n               WHERE user_id = $1\n                 AND (read, created_at, id) > (\n                     SELECT read, created_at, id FROM notifications WHERE id = $2\n                 )\n               ORDER BY read ASC, created_at DESC\n               LIMIT $3",
