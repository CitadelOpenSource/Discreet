{
  "db_name": "PostgreSQL",
  "query": "SELECT a.created_at, u.username as actor_username,\n                          a.action, a.target_type, a.target_id, a.chain_hash\n                   FROM audit_log a\n                   LEFT JOIN users u ON u.id = a.actor_id\n                   ORDER BY a.created_at DESC\n                   LIMIT $1",
