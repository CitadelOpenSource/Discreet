{
  "db_name": "PostgreSQL",
  "query": "SELECT f.id as friendship_id, f.friend_id, f.created_at,\n           u.username, u.display_name, u.avatar_url\n         FROM friendships f\n         JOIN users u ON u.id = f.friend_id\n         WHERE f.user_id = $1 AND f.status = 'pending'\n         ORDER BY f.created_at DESC",
